package pulumi:mypkg@0.0.1--0.0.0-NIGHTLY-ef13e21;

world mypkg-pulumi {
    import component:pulumi-wasm/register-interface@0.0.0-NIGHTLY-ef13e21;
    export func-with-secrets;
}

world mypkg-pulumi-client {
    import func-with-secrets;
}


interface func-with-secrets {

    use component:pulumi-wasm/output-interface@0.0.0-NIGHTLY-ef13e21.{output};

    record args {
        crypto-key: borrow<output>,
        plaintext: borrow<output>,
    }

    record res {
        ciphertext: output,
        crypto-key: output,
        id: output,
        plaintext: output,
    }

    invoke: func(
        args: args
    ) -> res;

}
